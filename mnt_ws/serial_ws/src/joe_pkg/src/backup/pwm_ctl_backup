#include <iostream>
#include <cstdlib>
#include "rclcpp/rclcpp.hpp"

class PWMController : public rclcpp::Node
{
public:
    PWMController()
        : Node("pwm_controller"), duty_cycle_(0), increasing_(true)
    {
        // 定时器回调周期为 100ms
        timer_ = this->create_wall_timer(
            std::chrono::milliseconds(100),
            std::bind(&PWMController::timer_callback, this));

        RCLCPP_INFO(this->get_logger(), "PWM Controller Node has been started.");
    }

private:
    void timer_callback()
    {
        // 输出当前占空比
        RCLCPP_INFO(this->get_logger(), "Current Duty Cycle: %d%%", duty_cycle_);

        // 调整占空比
        if (increasing_)
        {
            duty_cycle_++;
            if (duty_cycle_ >= 100)
            {
                increasing_ = false; // 开始下降
            }
        }
        else
        {
            duty_cycle_--;
            if (duty_cycle_ <= 0)
            {
                increasing_ = true; // 开始上升
            }
        }

        // 模拟设置PWM信号（实际应用中需要与硬件接口交互）
        set_pwm_signal(duty_cycle_);
    }

    void set_pwm_signal(int duty_cycle)
    {
        // 模拟设置PWM信号的占空比
        // 实际应用中可以通过硬件接口库设置PWM信号
        RCLCPP_DEBUG(this->get_logger(), "Setting PWM signal with duty cycle: %d%%", duty_cycle);
    }

    rclcpp::TimerBase::SharedPtr timer_;
    int duty_cycle_;
    bool increasing_;
};

int main(int argc, char *argv[])
{
    rclcpp::init(argc, argv);
    rclcpp::spin(std::make_shared<PWMController>());
    rclcpp::shutdown();
    return 0;
}


# Adding a new executable for pwm_ctl
add_executable(pwm_ctl src/pwm_ctl.cpp)
ament_target_dependencies(pwm_ctl rclcpp std_msgs)

install(TARGETS
  pwm_ctl
  DESTINATION lib/${PROJECT_NAME}
)